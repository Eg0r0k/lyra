{
  "name": "lyra-audio",
  "version": "0.1.11",
  "description": "Flexible audio player library with Web Audio API and HTML5 support",
  "author": "Eg0rk",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "release:patch": "pnpm typecheck && pnpm build && npm version patch && pnpm publish",
    "release:minor": "pnpm typecheck && pnpm build && npm version minor && pnpm publish",
    "release:major": "pnpm typecheck && pnpm build && npm version major && pnpm publish",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "hls.js": "^1.4.0"
  },
  "peerDependenciesMeta": {
    "hls.js": {
      "optional": true
    }
  },
  "keywords": [
    "audio",
    "player",
    "web-audio-api",
    "hls",
    "streaming",
    "music",
    "html5-audio"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Eg0r0k/lyra"
  },
  "bugs": {
    "url": "https://github.com/Eg0r0k/lyra/issues"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
